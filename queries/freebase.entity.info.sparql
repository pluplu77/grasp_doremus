PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX fb: <http://rdf.freebase.com/ns/>

SELECT DISTINCT ?id ?value ?type WHERE {
  # Get additional information
  {
    VALUES ?id { {IDS} }
    ?id fb:type.object.name ?value
    FILTER(LANG(?value) = "en")
    BIND("label" AS ?type)
  } UNION {
    VALUES ?id { {IDS} }
    ?id fb:common.topic.alias ?value
    FILTER(LANG(?value) = "en")
    BIND("alias" AS ?type)
  } UNION {
    VALUES ?id { {IDS} }
    ?id fb:common.topic.description ?value
    FILTER(LANG(?value) = "en")
    BIND("info" AS ?type)
  } UNION {
    VALUES ?id { {IDS} }
    ?id fb:common.topic.notable_types ?typ_ .
    ?typ_ fb:type.object.name ?typ
    FILTER(LANG(?typ) = "en")
    BIND(CONCAT("has type ", ?typ) AS ?value)
    BIND("info" AS ?type)
  } UNION {
    VALUES ?id { {IDS} }
    ?id fb:freebase.type_hints.mediator ?mediator
    FILTER(?mediator = "true")
    BIND("is compound value type / mediator type" AS ?value)
    BIND("info" AS ?type)
  }
}
ORDER BY ?id ?type ?value
